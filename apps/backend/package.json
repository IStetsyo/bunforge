{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "generate-types": "tsup src/router/index.ts --format esm --dts-only --out-dir ../../packages/shared-types/router",
    "watch-types": "tsup src/router/index.ts --format esm --dts-only --watch --out-dir ../../../packages/shared-types/router",
    "prebuild": "bun run generate-types",
    "dev": "bun run watch-types & bun run --watch src/index.ts",
    "build": "bun run generate-types && bun build --compile --target bun --outfile build/server src/index.ts"
  },
  "dependencies": {
    "@orpc/server": "^1.13.5",
    "elysia": "latest",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "bun-types": "latest",
    "tsup": "^8.5.1"
  },
  "module": "src/index.js"
}
